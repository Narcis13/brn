{
  "name": "takt",
  "version": "0.1.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "takt": "./src/cli.ts"
  },
  "scripts": {
    "orchestrate": "bun run .superclaude/orchestrator/loop.ts --mode=auto",
    "step": "bun run .superclaude/orchestrator/loop.ts --mode=step",
    "status": "bun run .superclaude/orchestrator/loop.ts --mode=interactive",
    "serve": "bun run src/cli.ts serve",
    "dev": "bun run serve",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
