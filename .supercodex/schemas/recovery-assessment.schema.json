{
  "$id": "recovery-assessment.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "unit_id",
    "current_phase",
    "latest_status",
    "recommendation",
    "can_resume",
    "summary",
    "drifts",
    "refs",
    "generated_at"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "unit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_phase": {
      "enum": [
        "intake",
        "clarify",
        "map",
        "research",
        "plan",
        "dispatch",
        "implement",
        "verify",
        "review",
        "integrate",
        "complete_task",
        "complete_slice",
        "reassess",
        "recover",
        "awaiting_human",
        "blocked",
        "complete"
      ]
    },
    "latest_status": {
      "enum": [
        "success",
        "failed",
        "blocked",
        "interrupted",
        "running"
      ]
    },
    "recommendation": {
      "enum": [
        "resume",
        "dispatch",
        "retry",
        "replan",
        "await_human",
        "restart",
        "none"
      ]
    },
    "can_resume": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "drifts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message",
          "ref"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "warning",
              "blocking"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
